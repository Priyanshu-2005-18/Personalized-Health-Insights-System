# =============================================================================
#  Health Insights System — Environment Variables
#  Copy this file to .env and fill in all values marked <CHANGE_ME>
#  NEVER commit .env to version control.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

# Docker image tag used for versioned deployments
IMAGE_TAG=1.0.0

# Target environment: development | staging | production
ENVIRONMENT=production


# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=health_insights
POSTGRES_USER=health_user
POSTGRES_PASSWORD=<CHANGE_ME>   # min 32 chars, no special shell chars

# Full DSN constructed in docker-compose.yml — set manually if running outside Docker
# DATABASE_URL=postgresql://health_user:<CHANGE_ME>@localhost:5432/health_insights

# Connection pool settings (used by SQLAlchemy / asyncpg if added later)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30


# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>       # min 24 chars
REDIS_DB=0
# REDIS_URL=redis://:<CHANGE_ME>@localhost:6379/0


# ─────────────────────────────────────────────────────────────────────────────
# FASTAPI / UVICORN
# ─────────────────────────────────────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8000

# Number of Uvicorn worker processes.
# Rule of thumb: (2 × CPU cores) + 1  — do not exceed 4 on < 2 GB RAM
API_WORKERS=2

# Logging level: debug | info | warning | error | critical
LOG_LEVEL=info

# Secret key used for signing tokens / sessions (generate with: openssl rand -hex 32)
SECRET_KEY=<CHANGE_ME>

# Allowed origins for CORS (JSON list). Use ["*"] for dev only.
CORS_ORIGINS=["https://yourdomain.com"]

# Rate limiting: max requests per minute per IP (0 = disabled)
RATE_LIMIT_RPM=120

# Max records per /predict/batch call
BATCH_MAX_SIZE=50

# Absolute path to the trained model artifact inside the container
MODEL_PATH=/app/ml/artifacts/health_score_model.joblib
MODEL_VERSION=1.0.0

# API prefix — keep in sync with Nginx proxy_pass location
API_PREFIX=/api/v1


# ─────────────────────────────────────────────────────────────────────────────
# REACT / VITE FRONTEND
# ─────────────────────────────────────────────────────────────────────────────

# Base URL the browser uses to reach the API.
# In production with Nginx reverse proxy this is just /api/v1 (same origin).
VITE_API_BASE_URL=/api/v1

# Application title shown in <title> and header
VITE_APP_NAME="Health Insights"

# Feature flags (true | false)
VITE_ENABLE_BATCH_SCORING=true
VITE_ENABLE_NOTIFICATIONS=true


# ─────────────────────────────────────────────────────────────────────────────
# NGINX
# ─────────────────────────────────────────────────────────────────────────────

# Your public domain name (used in Nginx server_name and SSL cert)
DOMAIN=yourdomain.com

# Email for Let's Encrypt expiry notices
LETSENCRYPT_EMAIL=admin@yourdomain.com


# ─────────────────────────────────────────────────────────────────────────────
# PGADMIN  (dev profile only)
# ─────────────────────────────────────────────────────────────────────────────

PGADMIN_EMAIL=admin@health.local
PGADMIN_PASSWORD=<CHANGE_ME>


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING (monitoring profile only)
# ─────────────────────────────────────────────────────────────────────────────

GRAFANA_USER=admin
GRAFANA_PASSWORD=<CHANGE_ME>


# ─────────────────────────────────────────────────────────────────────────────
# SECURITY HEADERS  (read by Nginx config)
# ─────────────────────────────────────────────────────────────────────────────

# Strict-Transport-Security max-age in seconds (31536000 = 1 year)
HSTS_MAX_AGE=31536000
