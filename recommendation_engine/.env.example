# ── Application ──────────────────────────────────────────────
APP_ENV=development
DEBUG=True
APP_VERSION=1.0.0

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Engine tuning (optional overrides) ───────────────────────
MAX_RECOMMENDATIONS=8
MAX_PER_CATEGORY=3
